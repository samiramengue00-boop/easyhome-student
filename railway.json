{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "gunicorn easyhome_student.wsgi:application --bind 0.0.0.0:$PORT --workers=1 --threads=2 --timeout=30",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}